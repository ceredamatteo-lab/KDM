res2$main
dev.off()
tests[[2]]<-res2$sig

dd<-acc
res3<-makePlot(dd,ntrain,nq=nquantiles,"Accuracy",toconsider=toc,pval=0.05,npeaks=ntrain,alternative="two",avg=avgfun)
pdf(paste0(data_folder,"Fig6_rbp_encode_pred_acc.pdf"),width=8,height=5)
res3$main
dev.off()
tests[[3]]<-res3$sig

pdf(paste0(data_folder,"Fig6_rbp_encode_pred_supp.pdf"),width=11,height=2)
ggarrange(plotlist=tests,ncol=3)
dev.off()

### END RBP_ENCODE PREDIZIONE

