dev.off()
tests[[1]]<-res1$sig

dd<-auprc
res2<-makePlot(dd,ntrain,nq=nquantiles,"auPRC",toconsider=toc,pval=0.05,npeaks=ntrain,alternative="two",avg=avgfun)
