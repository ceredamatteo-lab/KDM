### BEGIN RBP_ENCODE PREDIZIONE
metadata_folder="DATA/RDATA/"
load(paste0(metadata_folder,"METADATA_RBP-ENCODE.Rdata"))
good=which(einfo$nTrainPos>100)
ntrain<-einfo$nTrainPos[good]

load(paste0(data_folder,"prediction_RNAPROT_RBP-ENCODE.Rdata"))
load(paste0(data_folder,"rprediction_GRAPHPROT_RBP-ENCODE.Rdata"))
load(paste0(data_folder,"prediction_KDM_RBP-ENCODE.Rdata"))

graphprot=graphprot[good,]
rnaprot=rnaprot[good,]
kdm=kdm[good,]

acc<-data.frame(
  GraphProt=graphprot$ACC,
  RNAProt=rnaprot$ACC,
  KDM_LRLM=kdm$ACC
)

auroc<-data.frame(
  GraphProt=graphprot$AUROC,
  RNAProt=rnaprot$AUROC,
  KDM_LRLM=kdm$AUROC
)

auprc<-data.frame(
  GraphProt=graphprot$AUPRC,
  RNAProt=rnaprot$AUPRC,
  KDM_LRLM=kdm$AUPRC
)

nquantiles<-4
colnames(acc)[3]="KDM-LRLM"
colnames(auroc)[3]="KDM-LRLM"
colnames(auprc)[3]="KDM-LRLM"

toc<-colnames(acc)
avgfun<-"median"

tests<-list()
dd<-auroc
res1<-makePlot(dd,ntrain,nq=nquantiles,"auROC",toconsider=toc,pval=0.05,npeaks=ntrain,alternative="two",avg=avgfun)
