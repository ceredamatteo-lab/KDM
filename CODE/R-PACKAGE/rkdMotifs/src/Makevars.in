# Auto-generated by ./configure — do not edit by hand

PKG_CPPFLAGS = -I@PKG_ROOT@/src/geco2/include $(SHLIB_OPENMP_CXXFLAGS)

# PKG_LIBS carries both the -L/-l flags and the rpath entries.
# On Fedora/RHEL with redhat-hardened-ld the specs file rewrites the link
# command and PKG_LDFLAGS entries are silently dropped, so rpath MUST live
# here in PKG_LIBS to survive.
#
# $$ORIGIN is a GNU ld token meaning "the directory containing the .so that
# embeds this rpath".  For the installed package that is:
#   <prefix>/rkdMotifs/libs/rkdMotifs.so  →  $$ORIGIN/../libs/libgeco2.so
# The double $$ escapes shell expansion in sed so a literal $ORIGIN is written.
PKG_LIBS = -L@CMAKE_BUILD_DIR@ -lgeco2 \
           -Wl,-rpath,'$$ORIGIN/../libs' \
           -Wl,-rpath,@INSTALL_LIB_DIR@ \
           -Wl,-rpath,@CMAKE_BUILD_DIR@
